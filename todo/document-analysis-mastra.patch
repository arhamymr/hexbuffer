@@ -0,0 +1,146 @@
+import type { DocumentAnalysisInput, PreparedDocumentContext } from './document-analysis-schemas';
+
+const SECTION_LABELS: Record<string, string> = {
+  scope: 'Scope',
+  targetsDiscovered: 'Targets discovered',
+  dnsData: 'DNS data',
+  hostsAndServices: 'Hosts and services',
+  webObservations: 'Web observations',
+  endpoints: 'Endpoints',
+  authenticationDetails: 'Authentication details',
+  usersAndOrgInfo: 'Users / org info',
+  potentialVulnerabilities: 'Potential vulnerabilities',
+  evidence: 'Evidence',
+};
+
+const ROUTE_SIGNAL_PATTERNS = [
+  { pattern: /graphql/i, signal: 'GraphQL endpoint' },
+  { pattern: /admin|manage|dashboard/i, signal: 'Administrative route' },
+  { pattern: /auth|login|logout|token|session|oauth|sso/i, signal: 'Authentication route' },
+  { pattern: /upload|file|import|attachment/i, signal: 'File handling route' },
+  { pattern: /user|account|profile|member/i, signal: 'User data route' },
+  { pattern: /debug|trace|status|health|metrics/i, signal: 'Operational diagnostics route' },
+  { pattern: /reset|forgot|password/i, signal: 'Account recovery route' },
+];
+
+function compactText(value: string) {
+  return value
+    .split('\n')
+    .map((line) => line.trim())
+    .filter(Boolean)
+    .join('\n');
+}
+
+function uniqueSorted<T extends string | number>(values: T[]) {
+  return [...new Set(values)].sort();
+}
+
+function getRouteSignals(path: string, method: string, statusCodes: number[]) {
+  const signals = ROUTE_SIGNAL_PATTERNS
+    .filter(({ pattern }) => pattern.test(path))
+    .map(({ signal }) => signal);
+
+  if (method.toUpperCase() !== 'GET') {
+    signals.push('State-changing method');
+  }
+
+  if (statusCodes.some((status) => status >= 500)) {
+    signals.push('Server error observed');
+  }
+
+  if (statusCodes.includes(401) || statusCodes.includes(403)) {
+    signals.push('Access control boundary observed');
+  }
+
+  return uniqueSorted(signals);
+}
+
+export function prepareDocumentContext(input: DocumentAnalysisInput): PreparedDocumentContext {
+  const { document, analystPrompt, maxFindings } = input;
+  const sectionEntries = Object.entries(document.sections);
+  const sectionStats = sectionEntries.map(([key, value]) => ({
+    key,
+    characterCount: value.trim().length,
+    hasContent: value.trim().length > 0,
+  }));
+
+  const sectionText = sectionEntries
+    .map(([key, value]) => {
+      const label = SECTION_LABELS[key] ?? key;
+      const body = compactText(value);
+
+      return body ? `## ${label}\n${body}` : `## ${label}\nNo notes collected.`;
+    })
+    .join('\n\n');
+
+  const routeMap = new Map<string, {
+    host: string;
+    method: string;
+    path: string;
+    statuses: number[];
+    contentTypes: string[];
+    count: number;
+  }>();
+
+  for (const entry of document.apiEntries) {
+    const method = entry.method.toUpperCase();
+    const key = `${entry.host} ${method} ${entry.path}`;
+    const existing = routeMap.get(key) ?? {
+      host: entry.host,
+      method,
+      path: entry.path,
+      statuses: [],
+      contentTypes: [],
+      count: 0,
+    };
+
+    if (entry.responseStatus !== null) {
+      existing.statuses.push(entry.responseStatus);
+    }
+
+    if (entry.responseContentType) {
+      existing.contentTypes.push(entry.responseContentType);
+    }
+
+    existing.count += 1;
+    routeMap.set(key, existing);
+  }
+
+  const apiRoutes = [...routeMap.values()]
+    .map((route) => {
+      const statuses = uniqueSorted(route.statuses);
+
+      return {
+        ...route,
+        statuses,
+        contentTypes: uniqueSorted(route.contentTypes),
+        signals: getRouteSignals(route.path, route.method, statuses),
+      };
+    })
+    .sort((a, b) => b.signals.length - a.signals.length || b.count - a.count)
+    .slice(0, 50);
+
+  const emptySections = sectionStats
+    .filter((section) => !section.hasContent)
+    .map((section) => SECTION_LABELS[section.key] ?? section.key);
+
+  const deterministicSignals = [
+    emptySections.length > 0 ? `Empty document sections: ${emptySections.join(', ')}` : '',
+    document.apiEntries.length > 0 ? `Saved API entries: ${document.apiEntries.length}` : 'No saved API entries',
+    apiRoutes.some((route) => route.signals.includes('GraphQL endpoint')) ? 'GraphQL route appears in saved APIs' : '',
+    apiRoutes.some((route) => route.signals.includes('File handling route')) ? 'File handling route appears in saved APIs' : '',
+    apiRoutes.some((route) => route.signals.includes('Server error observed')) ? 'At least one saved route returned a server error' : '',
+  ].filter(Boolean);
+
+  return {
+    documentId: document.id,
+    title: document.title.trim() || document.name,
+    updatedAt: document.updatedAt,
+    sectionText,
+    sectionStats,
+    apiEntryCount: document.apiEntries.length,
+    apiRoutes,
+    deterministicSignals,
+    analystPrompt,
+    maxFindings,
+  };
+}
