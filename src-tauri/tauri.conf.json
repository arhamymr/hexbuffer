{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "0xbuffer",
  "version": "2026.0.26",
  "identifier": "com.0xbuffer",
  "build": {
    "beforeDevCommand": "pnpm sidecars:build && pnpm dev:clean",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm sidecars:build && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "0xbuffer",
        "decorations": false,
        "transparent": true,
        "visible": false,
        "width": 1000,
        "height": 800
      },
      {
        "label": "splashscreen",
        "url": "/splashscreen.html",
        "title": "0xbuffer",
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "center": true,
        "visible": true,
        "width": 492,
        "height": 199
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/ai-engine"
    ],
    "resources": [
      "resources/ghidra/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1ODlDNjUwQjEzMDYzODQKUldTRVl6Q3hVTWFKbGRENjAvWHZBUmhyN0p4Zm84RHU4TUl3ZHRLWVN4R3pTRFJrZkt2VGM2MXUK",
      "endpoints": [
        "https://dist.0xbuffer.com/latest.json"
      ]
    }
  }
}
