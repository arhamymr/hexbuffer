+import { z } from 'zod';
+
+export const documentSectionsSchema = z.object({
+  scope: z.string(),
+  targetsDiscovered: z.string(),
+  dnsData: z.string(),
+  hostsAndServices: z.string(),
+  webObservations: z.string(),
+  endpoints: z.string(),
+  authenticationDetails: z.string(),
+  usersAndOrgInfo: z.string(),
+  potentialVulnerabilities: z.string(),
+  evidence: z.string(),
+});
+
+export const savedApiEntrySchema = z.object({
+  id: z.string(),
+  sourceHistoryId: z.string(),
+  method: z.string(),
+  url: z.string(),
+  host: z.string(),
+  path: z.string(),
+  headers: z.record(z.string(), z.string()),
+  requestBody: z.string().nullable(),
+  responseStatus: z.number().nullable(),
+  responseContentType: z.string().nullable(),
+  capturedAt: z.number(),
+  savedAt: z.string(),
+});
+
+export const reconDocumentSchema = z.object({
+  id: z.string(),
+  name: z.string(),
+  title: z.string(),
+  sections: documentSectionsSchema,
+  apiEntries: z.array(savedApiEntrySchema),
+  createdAt: z.string(),
+  updatedAt: z.string(),
+});
+
+export const documentAnalysisInputSchema = z.object({
+  document: reconDocumentSchema,
+  analystPrompt: z.string().optional().default(''),
+  maxFindings: z.number().int().min(1).max(20).optional().default(10),
+});
+
+export const apiRouteSummarySchema = z.object({
+  host: z.string(),
+  method: z.string(),
+  path: z.string(),
+  statuses: z.array(z.number()),
+  contentTypes: z.array(z.string()),
+  count: z.number(),
+  signals: z.array(z.string()),
+});
+
+export const preparedDocumentContextSchema = z.object({
+  documentId: z.string(),
+  title: z.string(),
+  updatedAt: z.string(),
+  sectionText: z.string(),
+  sectionStats: z.array(z.object({
+    key: z.string(),
+    characterCount: z.number(),
+    hasContent: z.boolean(),
+  })),
+  apiEntryCount: z.number(),
+  apiRoutes: z.array(apiRouteSummarySchema),
+  deterministicSignals: z.array(z.string()),
+  analystPrompt: z.string(),
+  maxFindings: z.number(),
+});
+
+export const severitySchema = z.enum(['critical', 'high', 'medium', 'low', 'info']);
+
+export const analysisFindingSchema = z.object({
+  title: z.string(),
+  severity: severitySchema,
+  confidence: z.enum(['high', 'medium', 'low']),
+  evidence: z.array(z.string()),
+  rationale: z.string(),
+  validationSteps: z.array(z.string()),
+});
+
+export const documentAnalysisReportSchema = z.object({
+  documentId: z.string(),
+  title: z.string(),
+  executiveSummary: z.string(),
+  attackSurfaceSummary: z.array(z.string()),
+  findings: z.array(analysisFindingSchema),
+  apiObservations: z.array(z.object({
+    route: z.string(),
+    observation: z.string(),
+    risk: severitySchema,
+    nextStep: z.string(),
+  })),
+  evidenceGaps: z.array(z.string()),
+  prioritizedNextActions: z.array(z.string()),
+  confidence: z.enum(['high', 'medium', 'low']),
+});
+
+export type DocumentAnalysisInput = z.infer<typeof documentAnalysisInputSchema>;
+export type PreparedDocumentContext = z.infer<typeof preparedDocumentContextSchema>;
+export type DocumentAnalysisReport = z.infer<typeof documentAnalysisReportSchema>;
