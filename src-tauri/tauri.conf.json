{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hexbuffer",
  "version": "2026.0.76",
  "identifier": "com.hexbuffer.security",
  "build": {
    "beforeDevCommand": "pnpm dev:clean",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm sidecars:build && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "hexbuffer",
        "decorations": true,
        "transparent": true,
        "visible": false,
        "width": 1000,
        "height": 800,
        "maximized": true
      },
      {
        "label": "splashscreen",
        "url": "/splashscreen.html",
        "title": "hexbuffer",
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "center": true,
        "visible": true,
        "width": 492,
        "height": 199
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "externalBin": [
      "binaries/ai-engine"
    ],
    "resources": [
      "resources/ghidra/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1ODlDNjUwQjEzMDYzODQKUldTRVl6Q3hVTWFKbGRENjAvWHZBUmhyN0p4Zm84RHU4TUl3ZHRLWVN4R3pTRFJrZkt2VGM2MXUK",
      "endpoints": [
        "https://dist.0xbuffer.com/latest.json"
      ]
    }
  }
}
