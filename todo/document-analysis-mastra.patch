@@ -0,0 +1,96 @@
+import { createStep, createWorkflow } from '@mastra/core/workflows';
+import { prepareDocumentContext } from '../lib/document-analysis';
+import {
+  documentAnalysisInputSchema,
+  documentAnalysisReportSchema,
+  preparedDocumentContextSchema,
+  type DocumentAnalysisReport,
+} from '../lib/document-analysis-schemas';
+
+const prepareDocumentAnalysisContext = createStep({
+  id: 'prepare-document-analysis-context',
+  description: 'Normalizes a collected Apprecon recon document into compact analysis context.',
+  inputSchema: documentAnalysisInputSchema,
+  outputSchema: preparedDocumentContextSchema,
+  execute: async ({ inputData }) => {
+    if (!inputData) {
+      throw new Error('Document analysis input not found');
+    }
+
+    return prepareDocumentContext(inputData);
+  },
+});
+
+const analyzeDocument = createStep({
+  id: 'analyze-document',
+  description: 'Analyzes recon notes and saved APIs for risks, evidence gaps, and next actions.',
+  inputSchema: preparedDocumentContextSchema,
+  outputSchema: documentAnalysisReportSchema,
+  execute: async ({ inputData, mastra }) => {
+    if (!inputData) {
+      throw new Error('Prepared document context not found');
+    }
+
+    const agent = mastra?.getAgent('documentAnalysisAgent');
+    if (!agent) {
+      throw new Error('Document analysis agent not found');
+    }
+
+    const prompt = `Analyze this Apprecon recon document.
+
+Document:
+${JSON.stringify(inputData, null, 2)}
+
+Return no more than ${inputData.maxFindings} findings. Prioritize findings with evidence. Include evidence gaps when the notes are insufficient.`;
+
+    const response = await agent.generate<DocumentAnalysisReport>(
+      [{ role: 'user', content: prompt }],
+      {
+        structuredOutput: {
+          schema: documentAnalysisReportSchema,
+          instructions: 'Return a valid document analysis report. Do not include unsupported findings.',
+        },
+      }
+    );
+
+    return response.object;
+  },
+});
+
+const validateDocumentAnalysis = createStep({
+  id: 'validate-document-analysis',
+  description: 'Validates and normalizes the final document analysis report.',
+  inputSchema: documentAnalysisReportSchema,
+  outputSchema: documentAnalysisReportSchema,
+  execute: async ({ inputData }) => {
+    if (!inputData) {
+      throw new Error('Document analysis report not found');
+    }
+
+    const severityRank = {
+      critical: 5,
+      high: 4,
+      medium: 3,
+      low: 2,
+      info: 1,
+    };
+
+    const findings = [...inputData.findings]
+      .sort((a, b) => {
+        const severityDelta = severityRank[b.severity] - severityRank[a.severity];
+        if (severityDelta !== 0) {
+          return severityDelta;
+        }
+
+        return b.evidence.length - a.evidence.length;
+      })
+      .slice(0, 20);
+
+    return {
+      ...inputData,
+      findings,
+      attackSurfaceSummary: inputData.attackSurfaceSummary.slice(0, 12),
+      apiObservations: inputData.apiObservations.slice(0, 20),
+      evidenceGaps: inputData.evidenceGaps.slice(0, 12),
+      prioritizedNextActions: inputData.prioritizedNextActions.slice(0, 12),
+    };
+  },
+});
+
+const documentAnalysisWorkflow = createWorkflow({
+  id: 'document-analysis-workflow',
+  inputSchema: documentAnalysisInputSchema,
+  outputSchema: documentAnalysisReportSchema,
+})
+  .then(prepareDocumentAnalysisContext)
+  .then(analyzeDocument)
+  .then(validateDocumentAnalysis);
+
+documentAnalysisWorkflow.commit();
+
+export { documentAnalysisWorkflow };
