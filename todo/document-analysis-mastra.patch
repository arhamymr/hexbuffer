+import { Agent } from '@mastra/core/agent';
+import { Memory } from '@mastra/memory';
+import { documentAnalysisTool } from '../tools/document-analysis-tool';
+
+export const documentAnalysisAgent = new Agent({
+  id: 'document-analysis-agent',
+  name: 'Document Analysis Agent',
+  instructions: `You are a security reconnaissance analyst for Apprecon.
+
+Analyze collected recon documents and saved API observations. Your job is to correlate evidence, identify plausible risks, and recommend high-value validation steps.
+
+Rules:
+- Treat the input as analyst notes, not proof by itself.
+- Do not claim a vulnerability is confirmed unless concrete evidence is present.
+- Tie every finding to specific evidence from the document, saved APIs, or deterministic signals.
+- Prefer precise, testable next steps over generic advice.
+- Call out missing evidence when sections are thin or claims lack supporting request/response details.
+- Keep severity conservative when confidence is low.
+- Return structured output that matches the requested schema.`,
+  model: 'openai/gpt-5-mini',
+  tools: { documentAnalysisTool },
+  memory: new Memory(),
+});
